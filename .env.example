# agentic-clipper — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# Phase 1 scaffolding does not invoke any of these; Phase 2 will.

# === DB ===
AGENTIC_CLIPPER_DB=./data/main.db

# === Anthropic (Writer, Curator LLM judgment) ===
ANTHROPIC_API_KEY=

# === Seedance 2.0 — Atlas Cloud (primary, see docs/seedance_access.md) ===
ATLAS_CLOUD_API_KEY=
ATLAS_CLOUD_BASE_URL=https://api.atlascloud.ai

# === Seedance fallback — fal.ai ===
FAL_API_KEY=

# === ElevenLabs (selective TTS escalation; default is local Coqui) ===
ELEVENLABS_API_KEY=

# === YouTube Data API v3 ===
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

# === TikTok Content Posting API ===
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
# After audit approval, set to "true" to enable Direct Post; defaults to draft-only.
TIKTOK_AUDITED=false

# === Instagram Graph API ===
META_APP_ID=
META_APP_SECRET=
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=

# === Twitch Helix (Scout) ===
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# === Proxy pool (for backup-account fingerprint separation) ===
PROXY_POOL_URL=

# === Affiliate tracker (Cloudflare Worker + KV) ===
AFFILIATE_TRACKER_BASE_URL=
AFFILIATE_TRACKER_KV_NAMESPACE_ID=

# === Offsite backup (S3-compatible) ===
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# === Cost monitor ===
# Hard kill switch fires if month-to-date spend exceeds this (USD).
# Mirrors config/budget.yaml hard_kill_switch_usd.
BUDGET_HARD_KILL_USD=260
